  "types": "dist/types/index.d.ts",
  "bin": {
    "douyudm": "dist/cli/cmd.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "browser": "./dist/douyudm.browser.min.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "author": {
    "name": "flxxyz",
    "email": "i@mdzz.name"
  },
  "license": "MIT",
  "keywords": [
    "douyu",
    "danmu",
    "斗鱼",
    "弹幕",
    "stt",
    "serialize",
    "deserialize",
    "序列化",
    "typescript"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/flxxyz/douyudm"
  },
  "bugs": {
    "url": "https://github.com/flxxyz/douyudm/issues"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "lowdb": "^1.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/jest": "^29.5.14",
    "@types/lowdb": "^1.0.15",
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "jest": "^29.7.0",
    "rollup": "^4.55.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rollup -c rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "test": "jest",
    "test:stt": "jest __tests__/stt.test.ts",
    "test:packet": "jest __tests__/packet.test.ts",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
